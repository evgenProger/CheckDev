<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
         http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">
    <property name="now" value="now()" dbms="postgresql"/>
<changeSet id="02" author="Arsentev">

    <addUniqueConstraint tableName="exam_user"
                         columnNames="exam_id, key"
                         constraintName="exam_user_exam_id"
                         deferrable="true"
                         disabled="true"
                         initiallyDeferred="true"
                         schemaName="public"/>

    <addColumn schemaName="public"
               tableName="exam_user">
        <column name="total" type="int" defaultValueNumeric="1">
            <constraints nullable="false"/>
        </column>
    </addColumn>

    <addColumn schemaName="public"
               tableName="exam">
        <column name="position" type="int" defaultValueNumeric="0">
            <constraints nullable="false"/>
        </column>
    </addColumn>
</changeSet>
</databaseChangeLog>



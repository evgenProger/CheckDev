<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
         http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">
    <property name="now" value="now()" dbms="postgresql"/>
    <changeSet id="01" author="Arsentev">

        <createTable tableName="exam">
            <column autoIncrement="true" name="id" type="int">
                <constraints unique="true" nullable="false" primaryKey="true"/>
            </column>
            <column name="name" type="varchar(2000)"/>
            <column name="description" type="text"/>
            <column name="active" type="boolean" defaultValueBoolean="false"/>
            <column name="intro" type="varchar(2000)"/>
        </createTable>

        <createTable tableName="question">
            <column autoIncrement="true" name="id" type="int">
                <constraints unique="true" nullable="false" primaryKey="true"/>
            </column>
            <column name="name" type="varchar(2000)"/>
            <column name="description" type="text"/>
            <column name="pos" type="int"/>
            <column name="hint" type="text"/>
            <column name="exam_id" type="int">
                <constraints nullable="false" foreignKeyName="fk_question_exam" references="exam(id)"/>
            </column>
        </createTable>

        <createTable tableName="question_opt">
            <column autoIncrement="true" name="id" type="int">
                <constraints unique="true" nullable="false" primaryKey="true"/>
            </column>
            <column name="description" type="text"/>
            <column name="question_id" type="int" >
                <constraints nullable="false" foreignKeyName="fk_Question_opt_question" references="question(id)"/>
            </column>
            <column name="correct" type="boolean" defaultValueBoolean="false"/>
            <column name="pos" type="int"/>
        </createTable>

        <createTable tableName="exam_user">
            <column autoIncrement="true" name="id" type="int">
                <constraints unique="true" nullable="false" primaryKey="true"/>
            </column>
            <column name="exam_id" type="int">
                <constraints nullable="false" foreignKeyName="fk_exam_user_exam" unique="true" references="exam(id)"/>
            </column>
            <column name="result" type="int" defaultValueNumeric="0"/>
            <column name="start" type="timestamp" valueDate="${now}">
                <constraints nullable="false"/>
            </column>
            <column name="finish" type="timestamp"/>
            <column name="key" type="varchar(2000)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="answer">
            <column autoIncrement="true" name="id" type="int">
                <constraints unique="true" nullable="false" primaryKey="true"/>
            </column>
            <column name="question_id" type="int">
                <constraints nullable="false" foreignKeyName="fk_answer_question" references="question(id)"/>
            </column>
            <column name="exam_user_id" type="int">
                <constraints nullable="false" foreignKeyName="fk_answer_exam_user" references="exam_user(id)"/>
            </column>
        </createTable>

        <createTable tableName="answer_opt">
            <column autoIncrement="true" name="id" type="int">
                <constraints unique="true" nullable="false" primaryKey="true"/>
            </column>
            <column name="answer_id" type="int">
                <constraints nullable="false" foreignKeyName="fk_answer_opt_answer" references="answer(id)"/>
            </column>
            <column name="question_opt_id" type="int">
                <constraints nullable="false" foreignKeyName="fk_answer_opt_question_opt" references="question_opt(id)"/>
            </column>
        </createTable>
    </changeSet>
</databaseChangeLog>

<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
         http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">
    <property name="now" value="now()" dbms="postgresql"/>
    <changeSet id="01" author="Arsentev">

        <createTable tableName="vacancy">
            <column autoIncrement="true" name="id" type="int">
                <constraints unique="true" nullable="false" primaryKey="true"/>
            </column>
            <column name="name" type="varchar(2000)"/>
            <column name="location" type="varchar(2000)"/>
            <column name="rate" type="varchar(2000)"/>
            <column name="company" type="varchar(2000)"/>
            <column name="experience" type="varchar(2000)"/>
            <column name="published" type="timestamp"/>
            <column name="created" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="active" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="key" type="varchar(2000)"/>
        </createTable>

        <createTable tableName="stage">
            <column autoIncrement="true" name="id" type="int">
                <constraints unique="true" nullable="false" primaryKey="true"/>
            </column>
            <column name="name" type="varchar(2000)"/>
            <column name="description" type="varchar(2000)"/>
            <column name="pos" type="int"/>
            <column name="vacancy_id" type="int">
                <constraints nullable="false" foreignKeyName="fk_stage_vacancy" references="vacancy(id)"/>
            </column>
        </createTable>

        <createTable tableName="task">
            <column name="id" type="int" autoIncrement="true">
                <constraints nullable="false" unique="true" primaryKey="true"/>
            </column>
            <column name="name" type="varchar(2000)"/>
            <column name="type" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="stage_id" type="int">
                <constraints nullable="false" foreignKeyName="fk_task_stage" references="stage(id)"/>
            </column>
            <column name="pos" type="int"/>
            <column name="description" type="text"/>
        </createTable>

        <createTable tableName="task_value">
            <column name="id" type="int" autoIncrement="true">
                <constraints nullable="false" unique="true" primaryKey="true"/>
            </column>
            <column name="task_id" type="int">
                <constraints nullable="false" foreignKeyName="fk_task_value_task" references="task(id)"/>
            </column>
            <column name="value" type="text"/>
            <column name="info" type="varchar(2000)"/>
        </createTable>

        <createTable tableName="interview">
            <column name="id" type="int" autoIncrement="true">
                <constraints nullable="false" unique="true" primaryKey="true"/>
            </column>
            <column name="key" type="varchar(2000)">
                <constraints nullable="false"/>
            </column>
            <column name="start" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="finish" type="timestamp"/>
            <column name="vacancy_id" type="int">
                <constraints nullable="false" foreignKeyName="fk_interview_vacancy" references="vacancy(id)"/>
            </column>
            <column name="result" type="int" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint tableName="interview"
                             columnNames="id, key"
                             constraintName="interview_vacancy_id"
                             deferrable="true"
                             disabled="true"
                             initiallyDeferred="true"
                             schemaName="public"/>

        <createTable tableName="interview_task">
            <column name="id" type="int" autoIncrement="true">
                <constraints nullable="false" unique="true" primaryKey="true"/>
            </column>
            <column name="interview_id" type="int">
                <constraints nullable="false" foreignKeyName="fk_interview_task_interview" references="interview(id)"/>
            </column>
            <column name="task_id" type="int">
                <constraints nullable="false" foreignKeyName="Fk_interview_task_task" references="task(id)"/>
            </column>
            <column name="start" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="finish" type="timestamp"/>
        </createTable>

        <addUniqueConstraint tableName="interview_task"
                             columnNames="interview_id, task_id"
                             constraintName="interview_task_id"
                             deferrable="true"
                             disabled="true"
                             initiallyDeferred="true"
                             schemaName="public"/>

        <createTable tableName="interview_value">
            <column name="id" type="int" autoIncrement="true">
                <constraints nullable="false" unique="true" primaryKey="true"/>
            </column>
            <column name="interview_task_id" type="int">
                <constraints nullable="false" foreignKeyName="fk_interview_value_interview_task" references="interview_task(id)"/>
            </column>
            <column name="key" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="value" type="text"/>
            <column name="attach" type="bytea"/>
        </createTable>

        <createTable tableName="task_predict">
            <column name="id" type="int" autoIncrement="true">
                <constraints nullable="false" unique="true" primaryKey="true"/>
            </column>
            <column name="task_id" type="int">
                <constraints nullable="false" foreignKeyName="fk_task_predict_task" references="task(id)"/>
            </column>
            <column name="key" type="varchar(2000)"/>
            <column name="value" type="text"/>
        </createTable>

        <createTable tableName="report">
            <column name="id" type="int" autoIncrement="true">
                <constraints nullable="false" unique="true" primaryKey="true"/>
            </column>
            <column name="vacancy_id" type="int">
                <constraints nullable="false" foreignKeyName="fk_report_vacancy" references="vacancy(id)"/>
            </column>
            <column name="name" type="varchar(2000)"/>
            <column name="type" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="period" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="sorted_id" type="int">
                <constraints nullable="false" foreignKeyName="fk_report_task" references="task(id)"/>
            </column>
            <column name="sorted_by" type="int">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="report_field">
            <column name="id" type="int" autoIncrement="true">
                <constraints nullable="false" unique="true" primaryKey="true"/>
            </column>
            <column name="field_id" type="int">
                <constraints nullable="false" foreignKeyName="fk_field_id_task" references="task(id)"/>\
            </column>
            <column name="position" type="int">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="task_algo">
            <column name="id" type="int" autoIncrement="true">
                <constraints nullable="false" unique="true" primaryKey="true"/>
            </column>
            <column name="source" type="text"/>
            <column name="test" type="text"/>
            <column name="name" type="varchar(2000)"/>
            <column name="description" type="text"/>
            <column name="sname" type="varchar(2000)"/>
            <column name="tname" type="varchar(2000)"/>
            <column name="published" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="level" type="int">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="track">
            <column name="id" type="int" autoIncrement="true">
                <constraints nullable="false" unique="true" primaryKey="true"/>
            </column>
            <column name="interview_id" type="int">
                <constraints nullable="false" foreignKeyName="fk_track_interview_id" references="interview(id)"/>
            </column>
            <column name="stage_id" type="int">
                <constraints nullable="false" foreignKeyName="fk_track_stage" references="stage(id)"/>
            </column>
            <column name="task_id" type="int"/>
            <column name="position" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="passed" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="key" type="int" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="created" type="timestamp" valueDate="${now}">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint tableName="track"
                             columnNames="interview_id, stage_id, task_id"
                             constraintName="track_interview"
                             deferrable="true"
                             disabled="true"
                             initiallyDeferred="true"
                             schemaName="public"/>

        <createTable tableName="template_vacancy">
            <column name="id" type="int" autoIncrement="true">
                <constraints nullable="false" unique="true" primaryKey="true"/>
            </column>
            <column name="name" type="varchar(20)"/>
            <column name="description" type="varchar(2000)"/>
            <column name="template" type="text">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="team">
            <column name="id" type="int" autoIncrement="true">
                <constraints nullable="false" unique="true" primaryKey="true"/>
            </column>
            <column name="name" type="varchar(2000)"/>
            <column name="owner_key" type="varchar(2000)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="member">
            <column name="id" type="int" autoIncrement="true">
                <constraints nullable="false" unique="true" primaryKey="true"/>
            </column>
            <column name="team_id" type="int">
                <constraints nullable="false" foreignKeyName="fk_member_team" references="team(id)"/>
            </column>
            <column name="person_key" type="varchar(2000)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="permission">
            <column name="id" type="int" autoIncrement="true">
                <constraints nullable="false" unique="true" primaryKey="true"/>
            </column>
            <column name="team_id" type="int">
                <constraints nullable="false" foreignKeyName="fk_permission_team" references="team(id)"/>
            </column>
            <column name="vacancy_id" type="int">
                <constraints nullable="false" foreignKeyName="fk_permission_vacancy" references="vacancy(id)"/>
            </column>
            <column name="created" type="boolean"/>
            <column name="read" type="boolean"/>
            <column name="write" type="boolean"/>
        </createTable>

        <createTable tableName="comment">
            <column name="id" type="int" autoIncrement="true">
                <constraints nullable="false" unique="true" primaryKey="true"/>
            </column>
            <column name="interview_id" type="int">
                <constraints nullable="false" foreignKeyName="fk_comment_interview" references="interview(id)"/>
            </column>
            <column name="person_key" type="varchar(2000)">
                <constraints nullable="false"/>
            </column>
            <column name="text" type="text"/>
            <column name="created" type="timestamp" valueDate="${now}">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
</databaseChangeLog>

<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
         http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">
<changeSet id="02" author="Parsentev">

    <addColumn schemaName="public"
               tableName="vacancy">
        <column name="limit_time" type="bigint"/>
    </addColumn>
</changeSet>
    <changeSet id="03" author="Hincu">
        <addColumn tableName="stage">
            <column name="congratulate" type="text"/>
        </addColumn>
    </changeSet>
    <changeSet id="04" author="Hincu">
        <addColumn tableName="stage">
            <column name="failure" type="text"/>
        </addColumn>
    </changeSet>
    <changeSet id="05" author="Hincu">
        <addColumn tableName="vacancy">
            <column name="archive" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>
</databaseChangeLog>
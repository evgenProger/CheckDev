<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
         http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">

    <changeSet id="01" author="Arsentev Petr">
        <delete schemaName="public"
                tableName="track">
        </delete>
    </changeSet>

    <changeSet id="02" author="Arsentev Petr">
        <delete schemaName="public"
                tableName="task_value">
        </delete>
    </changeSet>

    <changeSet id="02.1" author="Arsentev Petr">
        <delete schemaName="public"
                tableName="task_predict">
        </delete>
    </changeSet>

    <changeSet id="02.2" author="Arsentev Petr">
        <delete schemaName="public"
                tableName="interview_value">
        </delete>
    </changeSet>

    <changeSet id="02.3" author="Arsentev Petr">
        <delete schemaName="public"
                tableName="interview_task">
        </delete>
    </changeSet>

    <changeSet id="02.4" author="Arsentev Petr">
        <delete schemaName="public"
                tableName="task">
        </delete>
    </changeSet>

    <changeSet id="03" author="Arsentev Petr">
        <delete schemaName="public"
                tableName="stage">
        </delete>
    </changeSet>

    <changeSet author="Arsentev Petr" id="04">
        <dropForeignKeyConstraint baseTableName="track" constraintName="track_interview"/>
    </changeSet>

    <changeSet author="Arsentev Petr" id="05">
        <dropColumn columnName="stage_id"
                    schemaName="public"
                    tableName="track"/>
    </changeSet>

    <changeSet author="Arsentev Petr" id="06">
        <dropColumn columnName="task_id"
                    schemaName="public"
                    tableName="track"/>
    </changeSet>

    <changeSet id="07" author="Arsentev Petr">
        <addColumn schemaName="public" tableName="track">
            <column name="task_id" type="int">
                <constraints nullable="false" foreignKeyName="fk_task_track" references="task(id)"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="08" author="Arsentev Petr">
        <addUniqueConstraint columnNames="interview_id, task_id"
                             constraintName="track_interview"
                             schemaName="public"
                             tableName="track"/>
    </changeSet>


    <changeSet author="Arsentev Petr" id="09">
        <dropColumn columnName="stage_id"
                    schemaName="public"
                    tableName="task"/>
    </changeSet>

    <changeSet author="Arsentev Petr" id="10">
        <dropTable schemaName="public"
                    tableName="stage"/>
    </changeSet>

    <changeSet id="11" author="Arsentev Petr">
        <addColumn schemaName="public" tableName="task">
            <column name="vacancy_id" type="int">
                <constraints nullable="false" foreignKeyName="fk_task_vacancy" references="vacancy(id)"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>